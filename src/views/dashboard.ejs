<h1><%= titulo %></h1>

<!-- Formulario de búsqueda -->
<div class="search-container">
    <form action="/paises/dashboard" method="GET" class="search-form">
        <input type="text" 
               name="nombre" 
               value="<%= busqueda %>" 
               placeholder="Buscar por nombre oficial..." 
               class="search-input">
        <button type="submit" class="btn search">🔍 Buscar</button>
        <a href="/paises/dashboard" class="btn clear">✖️ Limpiar</a>
    </form>
</div>

<% if (paises && paises.length > 0) { %>
    <div class="table-responsive">
        <table class="countries-table">
            <thead>
                <tr>
                    <th>Nombre oficial</th>
                    <th>Capital(es)</th>
                    <th>Limita con...</th>
                    <th>Área (km²)</th>
                    <th>Población</th>
                    <th>GINI</th>
                    <th>Zonas horarias</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% paises.forEach(pais => { %>
                    <tr>
                        <td><%= pais.name.official %></td>
                        <td><%= pais.capital && pais.capital.length ? pais.capital.join(', ') : '-' %></td>
                        <td><%= pais.borders && pais.borders.length ? pais.borders.join(', ') : '-' %></td>
                        <td><%= pais.area ? pais.area.toLocaleString() : '-' %></td>
                        <td><%= pais.population ? pais.population.toLocaleString() : '-' %></td>
                        <td><%= pais.gini || '-' %></td>
                        <td><%= pais.timezones && pais.timezones.length ? pais.timezones.join(', ') : '-' %></td>
                        <td class="table-actions">
                            <a href="/paises/editar/<%= pais._id %>" class="btn edit">✏️ Editar</a>
                            <button onclick="eliminar('<%= pais._id %>', '<%= pais.name.official %>')" class="btn delete">🗑️ Eliminar</button>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="alert warning">⚠️ No hay países cargados. Ejecutá el script de seed primero.</div>
<% } %>

<script>
    function eliminar(id, nombre) {
        if (confirm(`¿Eliminar el país "${nombre}"?`)) {
            fetch(`/paises/eliminar/${id}?_method=DELETE`, { method: 'POST' })
                .then(() => window.location.href = '/paises/dashboard')
                .catch(err => console.error('Error:', err));
        }
    }
</script>